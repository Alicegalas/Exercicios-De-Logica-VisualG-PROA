Algoritmo "EstruturaDescisaoEx15"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   : Jailson
// Descriçăo   : Saldo de conta em nuvem: Leia o saldo de créditos em uma
//conta AWS. Se o valor for menor que zero, exiba "Serviços suspensos", senăo
// exiba "Serviços ativos".
// Autor(a)    : Alice Ferreira
// Data atual  : 21/04/2026

Var
   // Seçăo de Declaraçőes das variáveis
   saldo: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Saldo de conta em nuvem.")
   escreval("")
   escreva("Digite o saldo de créditos: ")
   leia(saldo)
   escreval("")

   se saldo < 0 entao
      escreval("Serviços suspensos.")
   senao
      escreval("Serviços ativos.")
   fimse

Fimalgoritmo




