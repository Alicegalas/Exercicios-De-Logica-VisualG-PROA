Algoritmo "L01G"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   : Jailson
// Descriçăo   :   Ler quatro números inteiros e apresentar o resultado da
//adiçăo e multiplicaçăo, baseando-se na utilizaçăo do conceito da propriedade
// distributiva. Ou seja, se forem lidas as variáveis A, B, C, e D, devem ser
//somadas e multiplicadas A com B, A com C e A com D. Depois B com C, B com D
// e por fim C com D. Perceba que será necessário efetuar seis operaçőes
//de adiçăo e seis operaçőes de multiplicaçăo e apresentar doze resultados
// de saída.
// Autor(a)    : Alice Ferreira
// Data atual  : 20/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   a, b, c, d: inteiro


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Operaçőes com 4 números/variáveis.")
   escreval("")
   escreva("Digite o valor de A: ")
   leia(a)
   escreva("Digite o valor de B: ")
   leia(b)
   escreva("Digite o valor de C: ")
   leia(c)
   escreva("Digite o valor de D: ")
   leia(d)
   escreval("")

   escreval("Somas:")
   escreval("A + B = ", a + b)
   escreval("A + C = ", a + c)
   escreval("A + D = ", a + d)
   escreval("B + C = ", b + c)
   escreval("B + D = ", b + d)
   escreval("C + D = ", c + d)
   escreval("")

   escreval("Multiplicaçőes:")
   escreval("A * B = ", a * b)
   escreval("A * C = ", a * c)
   escreval("A * D = ", a * d)
   escreval("B * C = ", b * c)
   escreval("B * D = ", b * d)
   escreval("C * D = ", c * d)
   
Fimalgoritmo



