Algoritmo "L03G"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   : Jailson
// Descriçăo   : Inicializar os dois primeiros termos da sequęncia como 1 e 1.
//Exibir esses valores. Ro cálculo somando os dois últimos termos para gerar o
// próximo, até completar 15 termos. Atualizar os valores a cada repetiçăo e
//exibir toda a sequęncia.
// Autor(a)    : Alice Ferreira
// Data atual  : 21/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   n1, n2, n3: inteiro
   contadora: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
      escreval("Série de Fibonacci 15 termos.")
      escreval("")
   n1 <- 1
   n2 <- 1
   escreva(n1, " -")
   escreva(n2, " -")
   contadora <- 3

   enquanto contadora <= 15 faca
      n3 <- n1 + n2
      escreva(n3, " -")
      n1 <- n2
      n2 <- n3
      contadora <- contadora + 1
   fimenquanto
Fimalgoritmo