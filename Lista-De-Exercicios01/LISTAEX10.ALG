Algoritmo "ListaEx10"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   : Jailson
// Descriçăo   :Leia a base maior, a base menor e a altura de um trapézio e
//calcule sua área.
// Autor(a)    : Alice Ferreira
// Data atual  : 20/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   maior, menor, altura, area: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval(" Área do Trapézio")
   escreval("")
   escreva("Digite a base maior do Trapézio: ")
   leia(maior)
   escreval("")
   escreva("Digite a base menor do Trapézio: ")
   leia(menor)
   escreval("")
   escreva("Digite a altura do Trapézio: ")
   leia(altura)
   escreval("")
   area<- (((maior + menor) * altura) / 2)
   escreval("A área do Trapézio é: ",area)
Fimalgoritmo