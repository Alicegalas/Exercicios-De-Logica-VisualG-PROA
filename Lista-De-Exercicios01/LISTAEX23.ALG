Algoritmo "ListaEx23"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   :  Jailson
// Descriçăo   : Leia o lado de um quadrado e o raio de um círculo. Calcule
// as áreas e informe qual figura possui a maior área.
// Autor(a)    : Alice Ferreira
// Data atual  : 20/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   raio, lado, areac, areaq: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Comparaçăo de Áreas")
   escreval("")
   escreva("Digite o valor do raio do círculo: ")
   leia(raio)
   escreval("")
   escreva("Digite o valor do lado do quadrado: ")
   leia(lado)
   escreval("")
   areac<- ((raio^2) * 3.14)
   areaq<-lado* lado
   
 se areac > areaq entao
      escreval("A área do círculo é maior.")
   senao
      se areaq > areac entao
         escreval("A área do quadrado é maior.")
      senao
         escreval("As áreas săo iguais.")
      fimse
   fimse


Fimalgoritmo