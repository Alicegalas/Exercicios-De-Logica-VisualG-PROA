Algoritmo "ListaEx2"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   :  jailson
// Descriçăo   : Leia o valor do lado de um quadrado e calcule sua área.
// Autor(a)    : Alice Ferreira
// Data atual  : 19/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   lado , area: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Área quadrado.")
   escreval("")
   escreva("Digite o valor do lado do quadrado: ")
   leia(lado)
   escreval("")
   area<- lado * lado
   escreval("A área do quadrado é: ",area)

Fimalgoritmo