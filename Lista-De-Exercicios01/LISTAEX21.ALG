Algoritmo "ListaEx21"
// Disciplina   : [Lógica de Programaçăo VisualG]
// Professor   :  Jailson
// Descriçăo   :   Perímetro de um Retângulo
// Autor(a)    : Alice Ferreira
// Data atual  : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   largura, altura, perimetro: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Perímetro de um Retângulo")
   escreval("")
   escreva("Digite a largura do Retângulo: ")
   leia(largura)
   escreval("")
   escreva("Digite a altura do Retângulo: ")
   leia(altura)
   escreval("")
   perimetro<- ((largura + altura) * 2)
   escreval("O Perímetro do Retângulo é: ", perimetro)
Fimalgoritmo